# MeetLink 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# 数据库连接
DB_URL=jdbc:postgresql://localhost:5432/meetlink
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password

# 管理员初始化
MEETLINK_PASSWORD=your-admin-password
MEETLINK_ADMIN_EMAIL=admin@meetlink.com

# 在线限制
MEETLINK_ONLINE_NUM=100

# JWT 签名密钥（请使用随机字符串）
MEETLINK_JWT_SECRET=change-me-to-a-random-string
MEETLINK_JWT_EXPIRES_DAYS=30

# 日志路径
MEETLINK_LOG_PATH=/meetlink/logs/meetlink.log

# SSH 终端（生产环境建议关闭）
MEETLINK_SSH_ENABLED=false
MEETLINK_SSH_PASSWORD=

# 豆包 AI（可选）
MEETLINK_DOUBAO_ENABLED=false
MEETLINK_DOUBAO_API_KEY=
MEETLINK_DOUBAO_COUNT_LIMIT=5
MEETLINK_DOUBAO_LENGTH_LIMIT=50
MEETLINK_DOUBAO_MODEL=doubao-1-5-pro-32k-250115

# DeepSeek AI（可选）
MEETLINK_DEEPSEEK_ENABLED=false
MEETLINK_DEEPSEEK_API_KEY=
MEETLINK_DEEPSEEK_COUNT_LIMIT=2
MEETLINK_DEEPSEEK_LENGTH_LIMIT=50
MEETLINK_DEEPSEEK_MODEL=deepseek-v4-flash

# 文件上传大小限制
MEETLINK_FILE_SIZE=10MB

# 过期清理天数
MEETLINK_EXPIRES=7
